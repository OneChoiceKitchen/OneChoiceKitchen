  isActive     Boolean           @default(true)
  isDeleted    Boolean           @default(false)
  restaurantId String?
  branchId     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  branch       RestaurantBranch? @relation(fields: [branchId], references: [id])
}

model TiffinTerm {
  id           String            @id @default(uuid())
  title        String
  contentEn    String
  contentHi    String
  order        Int               @default(0)
  isActive     Boolean           @default(true)
  isDeleted    Boolean           @default(false)
  restaurantId String?
  branchId     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  branch       RestaurantBranch? @relation(fields: [branchId], references: [id])
}

model Order {
  id                  String            @id @default(uuid())
  userId              String
  restaurantId        String
  riderId             String?
  branchId            String?
  status              String            @default("PENDING")
  orderType           String            @default("DELIVERY") // DELIVERY, TAKEAWAY, DINE_IN
  tableReservationId  String?
  tableId             String?
  totalAmount         Float
  deliveryFee         Float             @default(0)
  tax                 Float             @default(0)
  paymentMethod       String            @default("ONLINE")
  paymentStatus       String            @default("PENDING")
  deliveryAddress     String
  deliveryLat         Float?
  deliveryLng         Float?
  specialInstructions String?
  codAmount           Float? // Cash on Delivery amount collected
  codCollected        Boolean           @default(false)
  itemsVerified       Boolean           @default(false) // Rider verified items at pickup
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id])
  restaurant          Restaurant        @relation(fields: [restaurantId], references: [id])
  tableReservation    TableReservation? @relation(fields: [tableReservationId], references: [id])
  table               RestaurantTable?  @relation(fields: [tableId], references: [id])
