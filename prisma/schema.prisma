  refunds             Refund[]
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  menuItemId     String
  quantity       Int
  price          Float
  customizations String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  deviceInfo   String?
  isValid      Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  userAgent String?
  status    String // 'SUCCESS' | 'FAILED'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FailedLoginAttempt {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  senderId    String
  message     String
  attachments String?
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  eventName String   @unique // E.g., 'ORDER_PLACED'
  channel   String // 'EMAIL', 'SMS', 'WHATSAPP'
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id             String    @id @default(uuid())
  name           String
  channel        String // EMAIL, SMS, WHATSAPP, PUSH
  targetAudience String // ALL_USERS, CUSTOMERS, RIDERS, etc.
  status         String    @default("DRAFT") // DRAFT, SCHEDULED, SENT
  scheduledFor   DateTime?
  sentAt         DateTime?
  subject        String?
  body           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Float
  type        String // CREDIT, DEBIT
  description String
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attendance {
  id           String    @id @default(uuid())
  employeeId   String
  date         DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       String    @default("PRESENT") // PRESENT, ABSENT, HALF_DAY, HOLIDAY, WEEKLY_OFF, LATE
  photoUrl     String?
  latitude     Float?
  longitude    Float?
  address      String?
  deviceInfo   String?
  workingMins  Int       @default(0)
  overtimeMins Int       @default(0)
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model LeaveRequest {
  id           String   @id @default(uuid())
  employeeId   String
  leaveType    String // CASUAL, SICK, EARNED, UNPAID
  startDate    DateTime
  endDate      DateTime
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  comments     String?
  approvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model LeaveBalance {
  id             String   @id @default(uuid())
  employeeId     String
  leaveType      String // CASUAL, SICK, EARNED
  totalAllocated Float
  used           Float    @default(0)
  carriedForward Float    @default(0)
  year           Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id             String    @id @default(uuid())
  employeeId     String
  month          Int
  year           Int
  basicSalary    Float
  allowances     Float     @default(0) // HRA, Conveyance, Bonus, Overtime
  deductions     Float     @default(0) // PF, ESI, TDS, Penalties
  netSalary      Float
  status         String    @default("PENDING") // PENDING, PROCESSED, PAID
  transactionRef String?
  paymentDate    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeDocument {
  id                 String    @id @default(uuid())
  employeeId         String
  documentType       String // AADHAAR, PAN, DRIVING_LICENSE, RESUME
  fileUrl            String
  expiryDate         DateTime?
  verificationStatus String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model GeofenceConfig {
  id           String   @id @default(uuid())
  restaurantId String?  @unique
  latitude     Float
  longitude    Float
  radiusMeters Float    @default(100.0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── WhatsApp Configuration (separate from SMS) ──────────────────────────────
model WhatsappConfig {
  id            String   @id @default(uuid())
  providerName  String   @unique // TWILIO, MSG91, META_CLOUD
  isActive      Boolean  @default(false)
  priority      Int      @default(1)
  dailyLimit    Int      @default(500)
  phoneNumberId String? // Meta Cloud API phone number ID
  accessToken   String? // Bearer token
  accountSid    String? // Twilio Account SID
  authToken     String? // Twilio Auth Token
  fromNumber    String? // WhatsApp sender number
  apiKey        String? // MSG91 auth key
  senderId      String? // MSG91 sender ID
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Multi-Branch Support ────────────────────────────────────────────────────
model RestaurantBranch {
  id                   String  @id @default(uuid())
  restaurantId         String
  name                 String
  address              String
  city                 String
  phone                String?
  secondaryPhone       String?
  email                String?
  secondaryEmail       String?
  lat                  Float?
  lng                  Float?
  mondayHours          String? @default("09:00 - 22:00")
  tuesdayHours         String? @default("09:00 - 22:00")
  wednesdayHours       String? @default("09:00 - 22:00")
  thursdayHours        String? @default("09:00 - 22:00")
  fridayHours          String? @default("09:00 - 22:00")
  saturdayHours        String? @default("09:00 - 22:00")
  sundayHours          String? @default("09:00 - 22:00")
  isActive             Boolean @default(true)
  isQrMenuEnabled      Boolean @default(false)
  isReservationEnabled Boolean @default(false)
  isDeliveryEnabled    Boolean @default(true)
  isTakeawayEnabled    Boolean @default(true)
  qrCodeUrl            String?

  // New Compliance & Branding Fields
  brandLogoUrl String?
  faviconUrl   String?
  fssaiNumber  String?
  fssaiDocUrl  String?
  gstNumber    String?
  gstDocUrl    String?
  panNumber    String?
  panDocUrl    String?

  // SEO Fields
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // SMO (Social Media Optimization) Fields
  ogTitle            String?
  ogDescription      String?
  ogImageUrl         String?
  twitterTitle       String?
  twitterDescription String?
  facebookUrl        String?
  twitterUrl         String?
  instagramUrl       String?
  youtubeUrl         String?

  collectionTags String?
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  restaurant           Restaurant            @relation(fields: [restaurantId], references: [id])
  reservations         TableReservation[]
  waitlistEntries      Waitlist[]
  tables               RestaurantTable[]
  menus                MenuItem[]
  tiffinMenus          TiffinMenu[]
  tiffinPlans          TiffinPlan[]
  tiffinFlyers         TiffinFlyer[]
  tiffinGlobalSettings TiffinGlobalSetting[]
  tiffinHolidays       TiffinHoliday[]
  tiffinTerms          TiffinTerm[]
  offers               TiffinOffer[]
}

// ── Franchise Relations ──────────────────────────────────────────────────────
model FranchiseRelation {
  id                 String     @id @default(uuid())
  parentRestaurantId String
  branchRestaurantId String
  royaltyPercent     Float      @default(0)
  contractDetails    String?
  startDate          DateTime   @default(now())
  status             String     @default("ACTIVE") // ACTIVE, SUSPENDED, TERMINATED
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  parentRestaurant   Restaurant @relation("FranchiseParent", fields: [parentRestaurantId], references: [id], onDelete: Cascade)
  branchRestaurant   Restaurant @relation("FranchiseBranch", fields: [branchRestaurantId], references: [id], onDelete: Cascade)
}

// ── Favorites ────────────────────────────────────────────────────────────────
model Favorite {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String?
  menuItemId   String?
  type         String   @default("RESTAURANT") // RESTAURANT, DISH
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Table Reservations ───────────────────────────────────────────────────────
model TableReservation {
  id               String            @id @default(uuid())
  userId           String
  restaurantId     String
  branchId         String?
  date             DateTime
  timeSlot         String
  partySize        Int
  status           String            @default("PENDING") // PENDING, CONFIRMED, SEATED, CANCELLED, COMPLETED
  confirmationCode String            @unique @default(uuid())
  specialRequests  String?
  tableNumber      String?
  tableId          String?
  depositAmount    Float?
  depositStatus    String            @default("PENDING") // PENDING, PAID, REFUNDED
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id])
  restaurant       Restaurant        @relation(fields: [restaurantId], references: [id])
  branch           RestaurantBranch? @relation(fields: [branchId], references: [id])
  table            RestaurantTable?  @relation(fields: [tableId], references: [id])
  orders           Order[]
}

model RestaurantTable {
  id           String             @id @default(uuid())
  restaurantId String
  branchId     String?
  tableNumber  String
  capacity     Int                @default(4)
  isAvailable  Boolean            @default(true)
  qrCodeUrl    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id])
  branch       RestaurantBranch?  @relation(fields: [branchId], references: [id])
  reservations TableReservation[]
  orders       Order[]
}

// ── Waitlist ─────────────────────────────────────────────────────────────────
model Waitlist {
  id                String            @id @default(uuid())
  userId            String
  restaurantId      String
  branchId          String?
  partySize         Int
  status            String            @default("WAITING") // WAITING, NOTIFIED, SEATED, CANCELLED
  notifiedAt        DateTime?
  notes             String?
  estimatedWaitTime Int? // in minutes
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id])
  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id])
  branch            RestaurantBranch? @relation(fields: [branchId], references: [id])
}

// ── Corporate Meal Plans ─────────────────────────────────────────────────────
model CorporateMealPlan {
  id              String                     @id @default(uuid())
  companyName     String
  contactName     String
  contactEmail    String
  contactPhone    String?
  planType        String                     @default("MONTHLY") // DAILY, WEEKLY, MONTHLY
  employeeCount   Int                        @default(1)
  monthlyBudget   Float                      @default(0)
  discountPercent Float                      @default(0)
  startDate       DateTime                   @default(now())
  endDate         DateTime?
  status          String                     @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED
  notes           String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  subscriptions   EmployeeMealSubscription[]
}

model EmployeeMealSubscription {
  id              String            @id @default(uuid())
  corporatePlanId String
  userId          String
  startDate       DateTime
  endDate         DateTime?
  billingCycle    String            @default("MONTHLY")
  status          String            @default("ACTIVE")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  corporatePlan   CorporateMealPlan @relation(fields: [corporatePlanId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
}

// ── Restaurant Compliance Documents ─────────────────────────────────────────
model RestaurantCompliance {
  id             String     @id @default(uuid())
  restaurantId   String
  documentType   String // FSSAI, HEALTH_CERT, FIRE_NOC, TRADE_LICENSE, GST
  documentNumber String?
  fileUrl        String
  issuedDate     DateTime?
  expiryDate     DateTime?
  status         String     @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  reviewNotes    String?
  reviewedById   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
}

// ── Payouts & Settlements ────────────────────────────────────────────────────
model PayoutRecord {
  id             String    @id @default(uuid())
  recipientId    String // userId of RIDER or PARTNER
  recipientType  String // RIDER, PARTNER
  periodStart    DateTime
  periodEnd      DateTime
  grossAmount    Float
  deductions     Float     @default(0)
  netAmount      Float
  status         String    @default("PENDING") // PENDING, APPROVED, PROCESSED, FAILED
  paymentMethod  String    @default("BANK_TRANSFER")
  transactionRef String?
  processedAt    DateTime?
  processedById  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ── Refunds ──────────────────────────────────────────────────────────────────
model Refund {
  id             String    @id @default(uuid())
  orderId        String
  userId         String
  amount         Float
  reason         String
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED, PROCESSED
  processedAt    DateTime?
  processedById  String?
  transactionRef String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  order          Order     @relation(fields: [orderId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
}

// ── Surge Pricing ────────────────────────────────────────────────────────────
model SurgePricing {
  id         String   @id @default(uuid())
  name       String
  startTime  String // HH:MM format
  endTime    String
  multiplier Float    @default(1.5)
  zone       String? // city/area name
  isActive   Boolean  @default(true)
  daysOfWeek String   @default("1,2,3,4,5,6,7") // comma-separated
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── SLA Configuration ────────────────────────────────────────────────────────
model SLAConfig {
  id                  String   @id @default(uuid())
  priority            String   @unique // URGENT, HIGH, MEDIUM, LOW
  responseTimeHours   Float    @default(1)
  resolutionTimeHours Float    @default(24)
  escalationHours     Float    @default(8)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ── Maps Configuration ───────────────────────────────────────────────────────
model MapsConfig {
  id            String   @id @default(uuid())
  providerName  String   @unique // GOOGLE_MAPS, OPENSTREETMAP
  isActive      Boolean  @default(false)
  apiKey        String?
  mapId         String? // Google Maps Map ID
  routingApiUrl String? // OSRM endpoint for OpenStreetMap
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Task Management System ───────────────────────────────────────────────────
model TaskProject {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model TaskModule {
  id        String   @id @default(uuid())
  name      String
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id             String       @id @default(uuid())
  taskId         String       @unique // e.g., TSK-1001
  title          String
  description    String? // Rich text
  projectId      String?
  project        TaskProject? @relation(fields: [projectId], references: [id])
  moduleId       String?
  module         TaskModule?  @relation(fields: [moduleId], references: [id])
  taskType       String // Feature, Bug, Enhancement, etc.
  priority       String // Critical, High, Medium, Low
  status         String // Backlog, To Do, In Progress, Code Review, Testing, UAT, Completed, Blocked, On Hold
  assigneeId     String?
  assignee       User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId     String?
  reporter       User?        @relation("TaskReporter", fields: [reporterId], references: [id])
  startDate      DateTime?
  dueDate        DateTime?
  estimatedHours Float?
  actualHours    Float?
  labels         String? // Comma separated or JSON
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  comments    TaskComment[]
  attachments TaskAttachment[]
  history     TaskHistory[]
  subtasks    TaskSubtask[]
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAttachment {
  id         String   @id @default(uuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileUrl    String
  fileName   String
  uploadedBy String
  user       User     @relation(fields: [uploadedBy], references: [id])
  createdAt  DateTime @default(now())
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // e.g., "Status changed from To Do to In Progress"
  createdAt DateTime @default(now())
}

model TaskSubtask {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  halls       Hall[]
}

model Hall {
  id             String         @id @default(uuid())
  restaurantId   String
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       EventCategory? @relation(fields: [categoryId], references: [id])
  name           String
  description    String?
  minCapacity    Int            @default(0)
  maxCapacity    Int            @default(100)
  basePrice      Float          @default(0)
  amenities      String?
  galleryUrls    String?
  locationString String?
  lat            Float?
  lng            Float?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  bookings HallBooking[]
}

model FoodPackage {
  id            String     @id @default(uuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  type          String
  mealType      String
  pricePerPlate Float      @default(0)
  minGuests     Int        @default(10)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  items    FoodPackageItem[]
  bookings HallBooking[]
}

model FoodPackageItem {
  id            String      @id @default(uuid())
  foodPackageId String
  foodPackage   FoodPackage @relation(fields: [foodPackageId], references: [id], onDelete: Cascade)
  menuItemId    String
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model AddonPackage {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  type         String
  price        Float      @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  bookings HallBookingAddon[]
}

model HallBooking {
  id              String       @id @default(uuid())
  customerId      String
  customer        User         @relation(fields: [customerId], references: [id])
  hallId          String
  hall            Hall         @relation(fields: [hallId], references: [id])
  foodPackageId   String?
  foodPackage     FoodPackage? @relation(fields: [foodPackageId], references: [id])
  eventDate       DateTime
  startTime       String
  endTime         String
  guestCount      Int          @default(0)
  status          String       @default("PENDING")
  totalAmount     Float        @default(0)
  advanceAmount   Float        @default(0)
  balanceAmount   Float        @default(0)
  specialRequests String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  addons HallBookingAddon[]
}

model HallBookingAddon {
  id             String       @id @default(uuid())
  bookingId      String
  booking        HallBooking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addonPackageId String
  addonPackage   AddonPackage @relation(fields: [addonPackageId], references: [id], onDelete: Cascade)
  price          Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ─── CHAT MODULE ─────────────────────────────────────────────────────────────

model ChatConversation {
  id           String            @id @default(uuid())
  type         String            // DIRECT | GROUP | SUPPORT_SESSION
  name         String?           // Group name (for GROUP type)
  description  String?
  avatarUrl    String?
  priority     String            @default("NORMAL") // NORMAL | HIGH | URGENT | CRITICAL
  isLocked     Boolean           @default(false)
  isArchived   Boolean           @default(false)
  createdById  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  id             String           @id @default(uuid())
  conversationId String
  userId         String
  role           String           @default("MEMBER") // MEMBER | ADMIN
  joinedAt       DateTime         @default(now())
  lastReadAt     DateTime?
  isMuted        Boolean          @default(false)
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           String           @default("TEXT") // TEXT | IMAGE | FILE | VOICE | SYSTEM
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  fileMime       String?
  replyToId      String?
  isEdited       Boolean          @default(false)
  isDeleted      Boolean          @default(false)
  isPinned       Boolean          @default(false)
  reactions      String           @default("{}") // JSON: { "👍": ["userId1"] }
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation(fields: [senderId], references: [id])
  replyTo        ChatMessage?     @relation("ReplyTo", fields: [replyToId], references: [id])
  replies        ChatMessage[]    @relation("ReplyTo")
  starredBy      ChatStarredMessage[]
}

model ChatStarredMessage {
  id        String      @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
}

model AiChatSession {
  id           String         @id @default(uuid())
  userId       String?        // null for anonymous sessions
  sessionToken String         @unique @default(uuid())
  status       String         @default("ACTIVE") // ACTIVE | ESCALATED | CLOSED | ARCHIVED
  channel      String         @default("WEB")    // WEB | MOBILE | WHATSAPP
  language     String         @default("en")
  metadata     String?        // JSON: browser, device, location
  ticketId     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     AiChatMessage[]
  supportReq   HumanSupportRequest?
  user         User?          @relation(fields: [userId], references: [id])
}

model AiChatMessage {
  id          String        @id @default(uuid())
  sessionId   String
  role        String        // USER | ASSISTANT | SYSTEM
  content     String
  intent      String?       // detected intent
  confidence  Float?        // AI confidence score 0-1
  metadata    String?       // JSON: quick replies, attachments
  createdAt   DateTime      @default(now())
  session     AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model HumanSupportRequest {
  id             String        @id @default(uuid())
  aiSessionId    String        @unique
  customerId     String?
  assignedToId   String?
  status         String        @default("PENDING") // PENDING | ACCEPTED | REJECTED | ASSIGNED | CLOSED
  reason         String?
  customerNote   String?
  adminNote      String?
  conversationId String?       // internal chat conversation created after approval
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  aiSession      AiChatSession @relation(fields: [aiSessionId], references: [id])
}

// Admin-configurable AI provider settings
model AiProviderConfig {
  id          String   @id @default(uuid())
  provider    String   @unique // OPENAI | GEMINI | ANTHROPIC | AZURE_OPENAI | CUSTOM
  displayName String
  apiKey      String?           // encrypted in production
  apiEndpoint String?           // custom endpoint
  model       String?           // e.g. gpt-4o, gemini-1.5-pro
  isActive    Boolean  @default(false)
  isPrimary   Boolean  @default(false)
  settings    String   @default("{}") // JSON: temperature, maxTokens, systemPrompt, etc.
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Chatbot FAQ / Knowledge Base entries
model ChatbotKnowledge {
  id         String   @id @default(uuid())
  category   String   // ORDERING | DELIVERY | PAYMENT | REFUND | SUBSCRIPTION | GENERAL
  question   String
  answer     String
  keywords   String   @default("[]") // JSON array of trigger keywords
  isActive   Boolean  @default(true)
  priority   Int      @default(0)    // higher = matched first
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Canned responses for human agents
model ChatCannedResponse {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String?
  shortCode String?  @unique // e.g. /hello /sorry /refund
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────
// PARTNER RBAC — Granular Feature-Level Permissions
// ──────────────────────────────────────────────────────────

// Stores which features a partner has been granted access to.
// module: 'food_ordering' | 'tiffin' | 'dining' | 'hall_party' | 'hrms' | 'marketing' | 'analytics' | 'finance'
// feature: granular feature ID e.g. 'fo_orders', 'mk_coupons', etc.
model PartnerFeaturePermission {
  id          String   @id @default(uuid())
  partnerId   String
  module      String   // module group ID
  feature     String   // granular feature ID
  isEnabled   Boolean  @default(false)
  grantedById String?  // Admin user ID who granted
  grantedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([partnerId, module, feature])
  @@index([partnerId])
}

// Tracks partner-initiated delete requests that need admin approval.
// Partners cannot directly delete data — they submit a request.
// Admin approves or rejects via the Partner Permissions admin page.
model PartnerDeleteRequest {
  id           String   @id @default(uuid())
  partnerId    String   // the partner requesting the delete
  module       String   // which module the entity belongs to
  entity       String   // model/table name e.g. 'Offer', 'Coupon', 'MenuItem'
  entityId     String   // the ID of the record to delete
  reason       String?  // optional reason provided by partner
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById String?  // admin who approved/rejected
  reviewedAt   DateTime?
  requestedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([partnerId])
  @@index([status])
}
