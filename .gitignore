# ============================================================
# ONE CHOICE KITCHEN — Root Monorepo .gitignore
# Covers: NestJS API, React portals, React Native apps,
#         Nx workspace, pnpm, Prisma, Docker, and CI/CD
# ============================================================

# ── Node / Package Managers ─────────────────────────────────
node_modules/
.pnpm-store/
.yarn/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
# Keep pnpm-lock.yaml — ensures reproducible installs

# ── Build Outputs ────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.output/
.svelte-kit/
storybook-static/
tmp/
temp/

# ── Nx Workspace ─────────────────────────────────────────────
.nx/cache/
.nx/workspace-data/
!.nx/version

# ── Vite ─────────────────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Prisma ───────────────────────────────────────────────────
prisma/generated/
node_modules/.prisma/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
dev.db
dev.db-journal

# ── Environment Variables ────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local
!.env.example
!.env.*.example

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.err.log
*.log.*
npm-debug.log*
.log
api.log
api.err.log
api_error.log
api_restart.log
admin-portal.log
admin-portal.err.log
partner-portal.log
partner-portal.err.log
rider-portal.log
rider-portal.err.log
maildev.log
maildev.err.log
web.log
web.err.log
mobile.log
mobile.err.log
partner.log
partner.err.log
rider.log
rider.err.log
serve.log

# ── Runtime / Process ────────────────────────────────────────
service_pids.txt
.service-pids
*.pid
*.pid.lock
.lock

# ── Local DB Seed Backups ────────────────────────────────────
dev.db.seed-backup*
*.seed-backup*

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
cypress/videos/
cypress/screenshots/
junit.xml
*.spec.js.snap

# ── Cache Directories ────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
.prettiercache
.babel_cache/
*.cache

# ── IDE / Editor ─────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# ── OS Generated ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Docker ───────────────────────────────────────────────────
docker-volumes/
.docker/

# ── React Native / Expo ──────────────────────────────────────
.expo/
.expo-shared/
*.jsbundle
android/app/build/
android/.gradle/
android/local.properties
ios/Pods/
ios/build/

# ── Scratch / Temp ───────────────────────────────────────────
scratch/
*.backup
*.bak
*.orig
*.tmp
*.swp
*.swo
out.txt
temp_rest.json
typecheck_output.txt
output_tiffin.txt
models.txt

# ── User-Uploaded / Generated Food Images (large runtime assets) ───────
# These are uploaded by admins/partners at runtime and served by the app.
# They must NOT be committed to git — use cloud storage (S3/GCS) in prod.
apps/web/public/images/Menu_Items/
apps/web/public/images/Tiffin_Items/
apps/web/public/map_placeholder.png
apps/admin/admin-portal/public/slider_background_image/
apps/admin/admin-portal/public/blogs_image/
apps/admin/admin-portal/public/discounts/
# Loose uploaded food images in admin public root (UUID-named or food-named)
apps/admin/admin-portal/public/*.png
apps/admin/admin-portal/public/*.jpg
apps/admin/admin-portal/public/*.jpeg
apps/admin/admin-portal/public/*.webp
# Exception: keep branding/logo assets
!apps/admin/admin-portal/public/logo*.png
!apps/admin/admin-portal/public/Logo*.webp
!apps/admin/admin-portal/public/favicon*

# ── Archives ─────────────────────────────────────────────────
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z
horizons-export-*.zip

# ── Certificates / Keys ──────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks

# ── AI Agent working dirs ────────────────────────────────────
.gemini/
.claude/
.codex/
.cursor/
.opencode/
opencode.json