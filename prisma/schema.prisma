generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String                     @id @default(uuid())
  email              String                     @unique
  password           String?
  name               String
  mobile             String?                    @unique
  googleId           String?                    @unique
  facebookId         String?                    @unique
  mfaEnabled         Boolean                    @default(false)
  mfaSecret          String?
  mfaType            String?
  emailVerified      Boolean                    @default(false)
  mobileVerified     Boolean                    @default(false)
  whatsappVerified   Boolean                    @default(false)
  profilePhoto       String?
  deactivatedAt      DateTime?
  notificationPrefs  String                     @default("{\"email\":true,\"sms\":true,\"whatsapp\":true,\"push\":true}")
  isLocked           Boolean                    @default(false)
  lockoutUntil       DateTime?
  otpCode            String?
  otpExpiry          DateTime?
  roleId             String?
  role               Role?                      @relation(fields: [roleId], references: [id])
  restaurantId       String?
  restaurant         Restaurant?                @relation(fields: [restaurantId], references: [id])
  isActive           Boolean                    @default(true)
  loyaltyPoints      Int                        @default(0)
  referralCode       String                     @unique @default(uuid())
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  addresses          Address[]
  subscriptions      CustomerSubscription[]
  pointHistory       PointHistory[]
  referredBy         Referral?                  @relation("ReferredBy")
  referralsMade      Referral[]                 @relation("ReferralsMade")
  reviews            Review[]
  rewardRedemptions  RewardRedemption[]
  supportTickets     SupportTicket[]
  auditLogs          AuditLog[]
  requestedApprovals ApprovalRequest[]          @relation("RequestedApprovals")
  approvedApprovals  ApprovalRequest[]          @relation("ApprovedApprovals")
  orders             Order[]
  sessions           Session[]
  loginHistory       LoginHistory[]
  failedLogins       FailedLoginAttempt[]
  walletTransactions WalletTransaction[]
  favorites          Favorite[]
  reservations       TableReservation[]
  waitlist           Waitlist[]
  employeeMealSubs   EmployeeMealSubscription[]
  refunds            Refund[]
  assignedTasks      Task[]                     @relation("TaskAssignee")
  reportedTasks      Task[]                     @relation("TaskReporter")
  taskComments       TaskComment[]
  taskAttachments    TaskAttachment[]
  taskHistories      TaskHistory[]
  hallBookings       HallBooking[]
  chatParticipants   ChatParticipant[]
  starredMessages    ChatStarredMessage[]
  aiChatSessions     AiChatSession[]
  sentMessages       ChatMessage[]
}

model Restaurant {
  id                   String                 @id @default(uuid())
  name                 String
  ownerName            String?
  email                String?
  secondaryEmail       String?
  mobile               String?
  secondaryMobile      String?
  businessDetails      String?
  cuisine              String?
  address              String?
  city                 String?
  lat                  Float?
  lng                  Float?
  rating               Float                  @default(0)
  reviewCount          Int                    @default(0)
  isFranchise          Boolean                @default(false)
  parentRestaurantId   String?
  isActive             Boolean                @default(true)
  isDeleted            Boolean                @default(false)
  deletedAt            DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  users                User[]
  orders               Order[]
  branches             RestaurantBranch[]
  franchiseParents     FranchiseRelation[]    @relation("FranchiseParent")
  franchiseBranches    FranchiseRelation[]    @relation("FranchiseBranch")
  reservations         TableReservation[]
  waitlist             Waitlist[]
  compliance           RestaurantCompliance[]
  tables               RestaurantTable[]
  menus                MenuItem[]
  tiffinMenus          TiffinMenu[]
  tiffinPlans          TiffinPlan[]
  tiffinFlyers         TiffinFlyer[]
  tiffinGlobalSettings TiffinGlobalSetting[]
  tiffinHolidays       TiffinHoliday[]
  tiffinTerms          TiffinTerm[]
  offers               TiffinOffer[]
  halls                Hall[]
  foodPackages         FoodPackage[]
  addonPackages        AddonPackage[]
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model ApprovalRequest {
  id            String   @id @default(uuid())
  entityType    String
  entityId      String?
  requestedData String
  status        String   @default("PENDING")
  requestedById String
  approvedById  String?
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requestedBy User  @relation("RequestedApprovals", fields: [requestedById], references: [id])
  approvedBy  User? @relation("ApprovedApprovals", fields: [approvedById], references: [id])
}

model PartnerRegistration {
  id              String   @id @default(uuid())
  restaurantName  String
  ownerName       String
  email           String   @unique
  mobile          String
  businessDetails String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RiderRegistration {
  id                String    @id @default(uuid())
  fullName          String
  email             String?
  mobile            String    @unique
  vehicleType       String    @default("Bike")
  vehicleVin        String?
  licensePlate      String?
  licenseNumber     String?
  licenseExpiry     DateTime?
  insuranceUrl      String?
  aadharUrl         String?
  photoUrl          String?
  bankAccountNumber String?
  bankIfsc          String?
  bankAccountName   String?
  whatsappVerified  Boolean   @default(false)
  emailVerified     Boolean   @default(false)
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED, SUSPENDED
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  street    String
  city      String
  state     String
  zipCode   String
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model TiffinMenu {
  id           String            @id @default(uuid())
  restaurantId String?
  name         String
  description  String?
  mealType     String
  dietType     String
  dayOfWeek    String?
  image        String?
  youtubeUrl   String?
  price        Float             @default(0)
  isAvailable  Boolean           @default(true)
  isDeleted    Boolean           @default(false)
  date         DateTime?
  calories     Int?
  branchId     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  branch       RestaurantBranch? @relation(fields: [branchId], references: [id])
}

model SubscriptionPlan {
  id            String                 @id @default(uuid())
  name          String
  description   String?
  durationDays  Int
  pricePerMeal  Float
  basePrice     Float
  dietType      String
  mealType      String
  isActive      Boolean                @default(true)
  subscriptions CustomerSubscription[]
}

model CustomerSubscription {
  id           String             @id @default(uuid())
  restaurantId String?
  userId       String
  planId       String
  startDate    DateTime
  endDate      DateTime
  status       String             @default("ACTIVE")
  deliveryLat  Float
  deliveryLng  Float
  deliveryFee  Float              @default(0)
  packagingFee Float              @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  invoices     BillingInvoice[]
  plan         SubscriptionPlan   @relation(fields: [planId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  schedules    DeliverySchedule[]
}

model DeliverySchedule {
  id             String               @id @default(uuid())
  subscriptionId String
  date           DateTime
  mealType       String
  status         String               @default("PENDING")
  riderId        String?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  customizations String?
  subscription   CustomerSubscription @relation(fields: [subscriptionId], references: [id])
}

model BillingInvoice {
  id             String               @id @default(uuid())
  subscriptionId String
  amount         Float
  tax            Float                @default(0)
  totalAmount    Float
  status         String               @default("PENDING")
  paymentMethod  String?
  receiptUrl     String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  subscription   CustomerSubscription @relation(fields: [subscriptionId], references: [id])
}

model TenantSetting {
  id                      String   @id @default(uuid())
  restaurantName          String
  logoUrl                 String?
  themeColor              String   @default("#3b82f6")
  currency                String   @default("INR")
  operatingHours          String   @default("09:00 - 22:00")
  deliveryRadius          Float    @default(5.0)
  activeModules           String   @default("dashboard,crm,dispatch,menu,orders,payments,inventory,workforce,printing")
  isEmployeeModuleEnabled Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model PaymentConfig {
  id            String   @id @default(uuid())
  gatewayName   String   @unique
  isEnabled     Boolean  @default(false)
  isSandbox     Boolean  @default(true)
  apiKey        String?
  apiSecret     String?
  merchantId    String?
  publicKey     String?
  webhookSecret String?
  activeMethods String   @default("upi,cards,netbanking")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StorageConfig {
  id           String   @id @default(uuid())
  providerName String   @unique // e.g., "LOCAL", "AWS_S3", "GCS", "AZURE_BLOB"
  isActive     Boolean  @default(false)
  accessKey    String?
  secretKey    String?
  bucketName   String?
  region       String?
  endpointUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuthConfig {
  id           String   @id @default(uuid())
  providerName String   @unique // e.g., "GOOGLE", "FACEBOOK", "APPLE"
  isEnabled    Boolean  @default(false)
  clientId     String?
  clientSecret String?
  callbackUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AiConfig {
  id           String   @id @default(uuid())
  providerName String   @unique // e.g., "GEMINI", "OPENAI"
  isActive     Boolean  @default(false)
  apiKey       String?
  modelName    String?  @default("gemini-1.5-flash-latest")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TaxRule {
  id        String   @id @default(uuid())
  name      String
  rate      Float
  region    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Coupon {
  id         String   @id @default(uuid())
  code       String   @unique
  discount   Float
  type       String   @default("PERCENT")
  expiryDate DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model InventoryItem {
  id         String    @id @default(uuid())
  name       String
  sku        String    @unique
  quantity   Int
  threshold  Int       @default(10)
  warehouse  String    @default("Main Kitchen")
  supplierId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
}

model Supplier {
  id        String          @id @default(uuid())
  name      String
  contact   String
  email     String?
  createdAt DateTime        @default(now())
  items     InventoryItem[]
}

model Employee {
  id           String    @id @default(uuid())
  userId       String?   @unique // Link to User for ESS login
  restaurantId String?
  name         String
  email        String    @unique
  mobile       String?
  role         String    @default("STAFF") // RIDER, MANAGER, CHEF, etc.
  designation  String? // Custom designation
  status       String    @default("ACTIVE") // ACTIVE, SUSPENDED, TERMINATED
  baseSalary   Float     @default(0.0)
  joiningDate  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  shifts      Shift[]
  attendances Attendance[]
  leaveReqs   LeaveRequest[]
  leaveBals   LeaveBalance[]
  payrolls    Payroll[]
  documents   EmployeeDocument[]
}

model Shift {
  id         String   @id @default(uuid())
  employeeId String
  name       String   @default("General") // Morning, Evening, Custom
  dayOfWeek  String
  startTime  String
  endTime    String
  breakMins  Int      @default(60)
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model EmailConfig {
  id           String   @id @default(uuid())
  providerName String   @unique
  isActive     Boolean  @default(false)
  priority     Int      @default(1)
  dailyLimit   Int      @default(1000)
  config       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SmsConfig {
  id           String   @id @default(uuid())
  providerName String   @unique
  isActive     Boolean  @default(false)
  priority     Int      @default(1)
  dailyLimit   Int      @default(500)
  config       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Blog {
  id                   String    @id @default(uuid())
  title                String
  slug                 String    @unique
  category             String
  author               String
  excerpt              String?
  readTime             Int       @default(5)
  seoTitle             String?
  seoDescription       String?
  scheduledPublishDate DateTime?
  publishDate          DateTime  @default(now())
  content              String
  views                Int       @default(0)
  likes                Int       @default(0)
  featuredImage        String?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  comments             Comment[]
}

model Comment {
  id          String    @id @default(uuid())
  blogId      String
  authorName  String
  authorEmail String?
  content     String
  status      String    @default("PENDING")
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  parent      Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentToComment")
  blog        Blog      @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

model Reward {
  id             String             @id @default(uuid())
  name           String
  description    String
  pointsRequired Int
  rewardType     String             @default("DISCOUNT")
  code           String?
  imageUrl       String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  redemptions    RewardRedemption[]
}

model RewardRedemption {
  id        String   @id @default(uuid())
  userId    String
  rewardId  String
  points    Int
  createdAt DateTime @default(now())
  reward    Reward   @relation(fields: [rewardId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model PointHistory {
  id        String   @id @default(uuid())
  userId    String
  action    String
  points    Int
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Referral {
  id             String   @id @default(uuid())
  referrerId     String
  referredEmail  String
  referredUserId String?  @unique
  status         String   @default("PENDING")
  rewardPoints   Int      @default(500)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referredUser   User?    @relation("ReferredBy", fields: [referredUserId], references: [id])
  referrer       User     @relation("ReferralsMade", fields: [referrerId], references: [id])
}

model Review {
  id           String   @id @default(uuid())
  userId       String?
  customerName String
  rating       Int
  comment      String
  photoUrl     String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id])
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String   @default("General")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id            String          @id @default(uuid())
  userId        String?
  email         String
  subject       String
  message       String
  category      String          @default("GENERAL") // GENERAL, ORDER, DELIVERY, ACCOUNT, REFUND, PAYMENT
  priority      String          @default("MEDIUM") // URGENT, HIGH, MEDIUM, LOW
  status        String          @default("OPEN") // OPEN, IN_PROGRESS, ESCALATED, RESOLVED, CLOSED
  assignedTo    String? // userId of support agent
  portalSource  String          @default("CUSTOMER") // CUSTOMER, PARTNER, RIDER, ADMIN
  slaDeadline   DateTime?
  slaBreached   Boolean         @default(false)
  rating        Int? // 1-5 after resolution
  ratingComment String?
  attachments   String? // JSON array of file URLs
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User?           @relation(fields: [userId], references: [id])
  messages      TicketMessage[]
}

model DeliverySetting {
  id                      String   @id @default(uuid())
  restaurantAddress       String   @default("One Choice Kitchen, Patna")
  restaurantLat           Float    @default(25.5941)
  restaurantLng           Float    @default(85.1376)
  enableDistanceCharges   Boolean  @default(true)
  freeDeliveryDistance    Float    @default(3.0)
  perKmCharge             Float    @default(8.0)
  minimumDeliveryCharge   Float    @default(0.0)
  maximumDeliveryCharge   Float?
  enableDistanceMargin    Boolean  @default(false)
  distanceMarginValue     Float    @default(0.0)
  applyMarginBeforeCharge Boolean  @default(true)
  googleMapsApiKey        String?
  allowPayOnDelivery      Boolean  @default(true)
  minimumOrderValue       Float    @default(0.0)
  updatedAt               DateTime @updatedAt
}

model MenuItem {
  id           String    @id @default(uuid())
  restaurantId String?
  branchId     String?
  name         String
  description  String?
  price        Float
  image        String?
  diet         String    @default("VEG")
  category     String    @default("Main")
  isAvailable  Boolean   @default(true)
  prepTime     Int       @default(20)
  isPopular    Boolean   @default(false)
  rating       Float     @default(4.5)
  reviewCount  Int       @default(0)
  sortOrder    Int       @default(0)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // SEO Fields
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // SMO Fields
  ogTitle            String?
  ogDescription      String?
  ogImageUrl         String?
  twitterTitle       String?
  twitterDescription String?
  youtubeUrl         String?

  attributes       ProductAttribute[]
  orderItems       OrderItem[]
  restaurant       Restaurant?        @relation(fields: [restaurantId], references: [id])
  branch           RestaurantBranch?  @relation(fields: [branchId], references: [id])
  foodPackageItems FoodPackageItem[]
}

model PortalSlider {
  id          String   @id @default(uuid())
  portal      String
  title       String
  description String
  buttonText  String
  link        String
  bgColor     String
  fontColor   String
  btnColor    String
  imageUrl    String?
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductAttribute {
  id         String                   @id @default(uuid())
  menuItemId String
  name       String
  type       String                   @default("SINGLE")
  isRequired Boolean                  @default(false)
  sortOrder  Int                      @default(0)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  menuItem   MenuItem                 @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options    ProductAttributeOption[]
}

model ProductAttributeOption {
  id              String           @id @default(uuid())
  attributeId     String
  name            String
  additionalPrice Float            @default(0)
  isDefault       Boolean          @default(false)
  isAvailable     Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  attribute       ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
}

model SeoMetadata {
  id                 String   @id @default(uuid())
  pageName           String   @unique
  title              String
  description        String?
  keywords           String?
  canonicalUrl       String?
  robots             String   @default("index, follow")
  ogTitle            String?
  ogDescription      String?
  ogImageUrl         String?
  ogUrl              String?
  twitterTitle       String?
  twitterDescription String?
  twitterImageUrl    String?
  schemaMarkup       String?
  updatedAt          DateTime @updatedAt
}

model StaticPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  section   String   @default("Company")
  isActive  Boolean  @default(true)
  portals   String   @default("web") // comma separated string e.g. "web,partner,rider"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSettings {
  id                    String   @id @default(uuid())
  siteName              String   @default("One Choice Kitchen")
  tagline               String   @default("Online Home-Style Food, Tiffin & Meal Services")
  logoUrl               String?
  faviconUrl            String?
  contactEmail          String?
  contactPhone          String?
  facebookUrl           String?
  twitterUrl            String?
  instagramUrl          String?
  updatedAt             DateTime @updatedAt
  linkedinUrl           String?
  transparentFaviconUrl String?
}

model TiffinFlyer {
  id           String            @id @default(uuid())
  type         String            @unique
  title        String
  imageUrl     String?
  isActive     Boolean           @default(true)
  restaurantId String?
  branchId     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  branch       RestaurantBranch? @relation(fields: [branchId], references: [id])
}

model TiffinGlobalSetting {
  id                     String            @id @default(uuid())
  deliveryIncludedKm     Int               @default(3)
  extraKmCharge          Float             @default(8)
  shopPickupDiscountPct  Float             @default(5)
  notesText              String?
  qrCodeUrl              String?
  breakfastTime          String            @default("7 - 10 AM")
  breakfastYoutubeUrl    String?
  lunchTime              String            @default("12 - 3 PM")
  lunchYoutubeUrl        String?
  dinnerTime             String            @default("7 - 10 PM")
  dinnerYoutubeUrl       String?
  trialDeliveryFee       Float             @default(40)
  trialPackagingFee      Float             @default(15)
  minPauseDays           Int               @default(5)
  upiId                  String?
  paymentInstructions    String?
  advancePaymentRequired Boolean           @default(true)
  businessName           String            @default("ONE CHOICE KITCHEN")
  businessAddress        String            @default("MADHUBAN COLONY, NEAR ABHIYANTA NAGAR, PATNA - 27")
  contactNumbers         String            @default("6299230165 / 7004838102")
  restaurantId           String?
  branchId               String?
  restaurant             Restaurant?       @relation(fields: [restaurantId], references: [id])
  branch                 RestaurantBranch? @relation(fields: [branchId], references: [id])
}

model TiffinHoliday {
  id            String            @id @default(uuid())
  title         String
  date          DateTime?
  isRecurring   Boolean           @default(false)
  recurringRule String?
  isActive      Boolean           @default(true)
  isDeleted     Boolean           @default(false)
  restaurantId  String?
  branchId      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  restaurant    Restaurant?       @relation(fields: [restaurantId], references: [id])
  branch        RestaurantBranch? @relation(fields: [branchId], references: [id])
}

model TiffinOffer {
  id              String  @id @default(uuid())
  title           String
  description     String?
  discountPct     Float   @default(0)
  minBookings     Int     @default(0)
  imageUrl        String?
  appliesToTiffin Boolean @default(true)
  appliesToMenu   Boolean @default(false)
  appliesToHome   Boolean @default(false)
  isHero          Boolean @default(false)
  isActive        Boolean @default(true)

  restaurantId String?
  restaurant   Restaurant?       @relation(fields: [restaurantId], references: [id])
  branchId     String?
  branch       RestaurantBranch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TiffinPlan {
