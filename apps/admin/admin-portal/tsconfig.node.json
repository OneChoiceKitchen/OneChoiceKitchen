{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "../../../dist/out-tsc",
    "types": ["node", "vite/client"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "vite.config.ts",
    "vite.config.*.ts"
  ]
}
